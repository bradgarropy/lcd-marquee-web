        "@tailwindcss/vite": "^4.1.13",
        "@types/node": "^22",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "eslint": "^10.0.3",
        "prettier": "^3.8.1",
        "tailwindcss": "^4.1.13",
        "typescript": "^5.9.2",
